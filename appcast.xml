        <item>
            <title>Version 0.9.13</title>
            <pubDate>Fri, 17 Apr 2026 17:30:00 +0000</pubDate>
            <sparkle:version>0.9.13</sparkle:version>
            <sparkle:shortVersionString>0.9.13</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.2</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h3>Mid-sentence diarization flicker fix</h3>
                <ul>
                <li>BleedFilter.splitBySpeaker absorbs short (&lt;0.5s) diar flickers into the neighbor speaker before splitting text</li>
                <li>EENDVCPipeline.mergeAndClean duration floor tightened 0.1s → 0.3s</li>
                <li>New "Re-process" menu item per recording for cleaning up pre-existing transcripts</li>
                </ul>
            ]]></description>
